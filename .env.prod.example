# ============================================================
# .env.prod — WebPonto PRODUÇÃO
# ============================================================
# Copie este arquivo para .env.prod e preencha os valores reais.
# NUNCA commite o .env.prod no Git.
# ============================================================

# ---- DOMÍNIOS (Traefik / Cloudflare) ----------------------
FRONTEND_DOMAIN=webponto.seudominio.com.br
API_DOMAIN=api.webponto.seudominio.com.br
APP_URL=https://webponto.seudominio.com.br

# ---- FRONTEND (URLs públicas — usadas no build Next.js) ---
NEXT_PUBLIC_API_URL=https://api.webponto.seudominio.com.br
NEXT_PUBLIC_WS_URL=wss://api.webponto.seudominio.com.br
NEXT_PUBLIC_COMPREFACE_URL=http://compreface-api:8080/api/v1
NEXT_PUBLIC_COMPREFACE_API_KEY=COLE_AQUI_A_API_KEY_DO_COMPREFACE

# ---- BANCO DE DADOS (PostgreSQL externo já no servidor) ----
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL=postgresql://webponto:SENHA_FORTE@localhost:5432/webponto_db

# ---- JWT (gere com: openssl rand -hex 64) ------------------
JWT_SECRET=GERE_UMA_CHAVE_FORTE_AQUI_openssl_rand_hex_64
JWT_EXPIRES_IN=7d

# ---- MINIO (externo já no servidor) -----------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=SEU_ACCESS_KEY_MINIO
MINIO_SECRET_KEY=SUA_SECRET_KEY_MINIO
MINIO_USE_SSL=false
# URL pública para acesso aos arquivos pelo navegador
MINIO_PUBLIC_URL=https://minio.seudominio.com.br

# ---- COMPREFACE -------------------------------------------
# API Key gerada no painel do CompreFace após subir os containers
COMPREFACE_API_KEY=COLE_AQUI_APOS_CRIAR_O_SERVICO_NO_COMPREFACE
COMPREFACE_THRESHOLD=0.85
COMPREFACE_DET_PROB=0.2
# Senha do banco interno do CompreFace (pode deixar postgres ou trocar)
COMPREFACE_DB_PASSWORD=postgres

# ---- CORS (domínios que podem chamar a API) ----------------
CORS_ORIGINS=https://webponto.seudominio.com.br

# ---- SMTP SISTEMA (recuperação de senha, alertas) ----------
# Usado APENAS para e-mails do sistema (não das empresas)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_senha_de_app_gmail
SMTP_FROM="WebPonto <seuemail@gmail.com>"

# ---- SENTRY (opcional — monitoramento de erros) ------------
# Crie uma conta em sentry.io e cole o DSN do projeto backend
SENTRY_DSN=
# DSN do projeto frontend (pode ser o mesmo ou diferente)
NEXT_PUBLIC_SENTRY_DSN=
