# CompreFace Configuration
# IMPORTANTE: Use a URL INTERNA do container (compreface-api:8080) no backend
# e a URL EXTERNA (localhost:8080) no frontend se necessário
NEXT_PUBLIC_COMPREFACE_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_COMPREFACE_API_KEY=dc71370c-718d-4e51-bcc5-3af5a31bafd2

# CompreFace Admin UI
# Acesse http://localhost:8000 para configurar (criar app e API key)

# Backend API
# NEXT_PUBLIC_API_URL: Usado pelo navegador (client-side)
NEXT_PUBLIC_API_URL=http://localhost:4000

# BACKEND_URL: Usado pelas API Routes do Next.js (server-side)
# Em desenvolvimento: http://backend:4000 (nome do container)
# Em produção: URL do backend (ex: https://api.webponto.com.br)
BACKEND_URL=http://backend:4000
