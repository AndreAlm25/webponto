# ============================================
# CONFIGURAÇÃO DO FRONTEND
# ============================================

# Backend API - URL que o navegador usa para chamar a API
# Desenvolvimento: http://localhost:4000
# Produção: https://api.web-ponto.conectarmais.com.br
NEXT_PUBLIC_API_URL=http://localhost:4000

# CompreFace - Reconhecimento Facial
NEXT_PUBLIC_COMPREFACE_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_COMPREFACE_API_KEY=dc71370c-718d-4e51-bcc5-3af5a31bafd2

# ============================================
# CONFIGURAÇÃO PARA PRODUÇÃO
# ============================================
#
# Crie um arquivo .env.production com:
#
# NEXT_PUBLIC_API_URL=https://api.web-ponto.conectarmais.com.br
# NEXT_PUBLIC_COMPREFACE_URL=https://face.web-ponto.conectarmais.com.br/api/v1
#
# Domínios necessários:
# 1. Frontend: web-ponto.conectarmais.com.br
# 2. Backend API: api.web-ponto.conectarmais.com.br
# 3. CompreFace (opcional): face.web-ponto.conectarmais.com.br
#
# ============================================
