generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                       String          @id @default(uuid()) @db.Uuid
  slug                     String?         @unique
  cnpj                     String          @unique
  legalName                String
  tradeName                String
  email                    String
  active                   Boolean         @default(true)
  logoUrl                  String?
  plan                     CompanyPlan     @default(TRIAL)
  status                   CompanyStatus   @default(ACTIVE)
  latitude                 Float?
  longitude                Float?
  allowRemoteClockIn       Boolean         @default(false)
  geofencingEnabled        Boolean         @default(false)
  geofencePolicy           GeofencePolicy?
  requireFacialRecognition Boolean         @default(false)
  requireLiveness          Boolean         @default(false)
  workingHoursStart        String          @default("08:00")
  workingHoursEnd          String          @default("18:00")
  workRegime               WorkRegime      @default(SINGLE_SHIFT)
  timezone                    String?
  enableTolerances            Boolean         @default(true)
  earlyEntryToleranceMinutes  Int             @default(10)
  lateExitToleranceMinutes    Int             @default(15)
  lateArrivalToleranceMinutes Int             @default(15)
  stripeCustomerId            String?
  stripeSubscriptionId     String?
  complianceLevel          ComplianceLevel @default(FULL)
  enforceWorkHours         Boolean         @default(true)
  enforceRestPeriod        Boolean         @default(true)
  enforceOvertimeRules     Boolean         @default(true)
  enforceTimeBankRules     Boolean         @default(true)
  allowNegativeBalance     Boolean         @default(false)
  customOvertimeRate       Decimal?        @default(1.5)
  customHolidayRate        Decimal?        @default(2.0)
  warnOnViolation          Boolean         @default(true)
  dashboardShowRecentEntries Boolean       @default(true)
  dashboardRecentEntriesLimit Int          @default(10)
  
  // Configurações de validação CLT para Férias (modo CUSTOM)
  vacationValidateAcquisitive   Boolean     @default(true)  // Validar período aquisitivo (12 meses)
  vacationValidateConcessivo    Boolean     @default(true)  // Validar período concessivo (vencimento)
  vacationValidateMaxPeriods    Boolean     @default(true)  // Validar máximo 3 períodos
  vacationValidateMinDays       Boolean     @default(true)  // Validar período mínimo 14 dias
  vacationValidateMaxSellDays   Boolean     @default(true)  // Validar máximo 10 dias vendidos
  vacationValidateStartDate     Boolean     @default(true)  // Validar início antes de feriado/fim de semana
  vacationValidatePaymentDeadline Boolean   @default(true)  // Validar prazo pagamento (2 dias antes)
  vacationEnforceDoublePayment  Boolean     @default(true)  // Obrigar pagamento em dobro se vencido
  
  // Configurações de visibilidade dos cards do Dashboard
  dashboardShowTotalEmployees Boolean      @default(true)
  dashboardShowTodayEntries   Boolean      @default(true)
  dashboardShowFacialRecognition Boolean   @default(true)
  dashboardShowRemoteClock    Boolean      @default(true)
  dashboardShowOvertime       Boolean      @default(true)
  dashboardShowAlerts         Boolean      @default(true)
  // Configurações do aplicativo
  successMessageDuration   Int             @default(10) // Tempo em segundos da mensagem de sucesso no terminal
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  address                  Address?        @relation("CompanyAddress")
  contactInfo              ContactInfo?    @relation("CompanyContactInfo")
  departments              Department[]
  employees                Employee[]
  faceProfiles             FaceProfile[]
  geofences                Geofence[]
  messageThreads           MessageThread[]
  messages                 Message[]
  notifications            Notification[]
  positions                Position[]
  timeEntries              TimeEntry[]
  users                    User[]
  payrolls                 Payroll[]
  payslips                 Payslip[]
  payrollConfig            PayrollConfig?
  customBenefits           CustomBenefit[]
  paymentGroups            PaymentGroup[]
  advances                 Advance[]
  rolePermissions          RolePermission[]
  auditLogs                AuditLog[]
  holidays                 Holiday[]
  medicalCertificates      MedicalCertificate[]
  vacations                Vacation[]
  vacationRequests         VacationRequest[]

  @@map("companies")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  companyId    String    @db.Uuid
  email        String    @unique
  password     String
  name         String
  cpf          String?   @unique
  phone        String?
  role         Role      @default(EMPLOYEE)
  active       Boolean   @default(true)
  avatarUrl    String?
  employeeId   String?   @unique @db.Uuid
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sentMessages      Message[]
  auditLogs         AuditLog[]
  approvedVacations Vacation[]
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee          Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Employee {
  id                     String          @id @default(uuid()) @db.Uuid
  companyId              String          @db.Uuid
  registrationId         String
  hireDate               DateTime
  baseSalary             Decimal         @db.Decimal(10, 2)
  positionId             String?         @db.Uuid
  departmentId           String?         @db.Uuid
  faceId                 String?
  faceRegistered         Boolean         @default(false)
  allowRemoteClockIn     Boolean         @default(false) // Permite bater ponto pelo painel (com geolocalização/cerca)
  allowFacialRecognition Boolean         @default(false)
  requireLiveness        Boolean         @default(false)
  timezone               String?
  active                 Boolean         @default(true)
  workStartTime          String          @default("08:00")
  workEndTime            String          @default("18:00")
  breakStartTime         String?
  breakEndTime           String?
  allowOvertime          Boolean         @default(false) // Permite hora extra
  allowOvertimeBefore    Boolean         @default(false) // Permite hora extra ANTES
  maxOvertimeBefore      Int?                            // Máximo em minutos ANTES
  allowOvertimeAfter     Boolean         @default(false) // Permite hora extra DEPOIS
  maxOvertimeAfter       Int?                            // Máximo em minutos DEPOIS
  overtimeRate           Decimal?        @db.Decimal(3, 2) // Taxa de hora extra (ex: 1.5 = 50% a mais)
  weekendRate            Decimal?        @db.Decimal(3, 2) // Taxa fim de semana (ex: 2.0 = 100% a mais)
  holidayRate            Decimal?        @db.Decimal(3, 2) // Taxa feriado (ex: 2.0 = 100% a mais)
  nightShiftRate         Decimal?        @db.Decimal(3, 2) // Taxa noturno (ex: 1.2 = 20% a mais)
  allowTimeBank          Boolean         @default(false) // Usa banco de horas (compensa em folga)
  minRestHours           Int             @default(11)    // Mínimo de descanso entre jornadas
  warnOnRestViolation    Boolean         @default(true)  // Alertar se violar descanso
  
  // Escala de trabalho
  workSchedule           WorkSchedule    @default(FIVE_TWO) // Escala (5x2, 6x1, 12x36, etc.)
  customWorkDaysPerMonth Int?                               // Dias/mês se escala CUSTOM
  
  // Benefícios individuais (sobrescreve config da empresa se preenchido)
  useCustomBenefits         Boolean   @default(false)           // Usa config individual?
  transportVoucherEnabled   Boolean?                            // VT habilitado (null = usa empresa)
  transportVoucherRate      Decimal?  @db.Decimal(5, 2)         // % desconto VT
  mealVoucherEnabled        Boolean?                            // VR habilitado
  mealVoucherValue          Decimal?  @db.Decimal(10, 2)        // Valor VR que recebe
  mealVoucherDiscount       Decimal?  @db.Decimal(5, 2)         // % desconto VR
  healthInsuranceEnabled    Boolean?                            // Plano saúde habilitado
  healthInsuranceValue      Decimal?  @db.Decimal(10, 2)        // Valor desconto plano saúde
  dentalInsuranceEnabled    Boolean?                            // Plano odonto habilitado
  dentalInsuranceValue      Decimal?  @db.Decimal(10, 2)        // Valor desconto plano odonto
  
  // Datas de pagamento personalizadas (sobrescreve config da empresa se preenchido)
  // As porcentagens sempre vêm da configuração global da empresa
  customPaymentDay1         Int?                                // Data personalizada parcela 1
  customPaymentDay2         Int?                                // Data personalizada parcela 2
  customPaymentDay3         Int?                                // Data personalizada parcela 3
  customPaymentDay4         Int?                                // Data personalizada parcela 4
  
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  geofenceId             String?         @db.Uuid
  address                Address?        @relation("EmployeeAddress")
  contactInfo            ContactInfo?    @relation("EmployeeContactInfo")
  company                Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department             Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  geofence               Geofence?       @relation(fields: [geofenceId], references: [id], onDelete: SetNull)
  position               Position?       @relation(fields: [positionId], references: [id], onDelete: SetNull)
  faceProfiles           FaceProfile[]
  messageThreads         MessageThread[]
  messages               Message[]
  sentMessages           Message[]       @relation("SenderEmployee")
  timeEntries            TimeEntry[]
  payslips               Payslip[]
  benefits               EmployeeBenefit[]
  advances               Advance[]
  paymentGroupId         String?         @db.Uuid
  paymentGroup           PaymentGroup?   @relation(fields: [paymentGroupId], references: [id], onDelete: SetNull)
  user                   User?
  medicalCertificates    MedicalCertificate[]
  vacations              Vacation[]
  vacationRequests       VacationRequest[]

  @@unique([companyId, registrationId])
  @@map("employees")
}

model TimeEntry {
  id                  String          @id @default(uuid()) @db.Uuid
  companyId           String          @db.Uuid
  employeeId          String          @db.Uuid
  timestamp           DateTime
  type                TimeEntryType
  method              ClockMethod     @default(MANUAL)
  location            String?
  notes               String?
  photoUrl            String?
  recognitionValid    Boolean         @default(false)
  similarity          Float?
  livenessScore       Float?
  livenessValid       Boolean?
  recognitionProvider FaceProvider?
  confidenceScore     Float?
  justification       String?
  latitude            Float?
  longitude           Float?
  accuracy            Float?
  clientCapturedAt    DateTime?
  geoMethod           String?
  source              String?
  ip                  String?
  geofenceStatus      GeofenceStatus?
  geofenceId          String?         @db.Uuid
  synchronized        Boolean         @default(true)
  status              TimeEntryStatus @default(VALID)
  isOvertime          Boolean         @default(false)    // É hora extra?
  overtimeStatus      OvertimeStatus? // Status da hora extra
  overtimeMinutes     Int?            // Minutos de hora extra
  overtimeType        OvertimeType?   // Tipo de hora extra
  overtimeRate        Decimal?        @db.Decimal(3, 2) // Taxa aplicada (ex: 1.5)
  overtimeValue       Decimal?        @db.Decimal(10, 2) // Valor em R$ da hora extra
  overtimeApprovedBy  String?         @db.Uuid // ID do gestor que aprovou
  overtimeApprovedAt  DateTime?       // Data da aprovação
  overtimeNotes       String?         // Observações sobre a hora extra
  exceedsLimit        Boolean         @default(false)    // Excedeu limite configurado
  isLate              Boolean         @default(false)    // Funcionário atrasou
  lateMinutes         Int?            // Minutos de atraso (após tolerância)
  violatesRest        Boolean         @default(false)    // Violou descanso mínimo
  restHours           Float?          // Horas de descanso que teve
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  company             Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee            Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, timestamp])
  @@index([companyId, timestamp])
  @@map("time_entries")
}

model Geofence {
  id           String     @id @default(uuid()) @db.Uuid
  companyId    String     @db.Uuid
  name         String
  centerLat    Float
  centerLng    Float
  radiusMeters Int
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  employees    Employee[]
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, active])
  @@map("geofences")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  companyId String           @db.Uuid
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Position {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  companyId String     @db.Uuid
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([name, companyId])
  @@map("positions")
}

model Department {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  companyId String     @db.Uuid
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([name, companyId])
  @@map("departments")
}

model FaceProfile {
  id         String            @id @default(uuid()) @db.Uuid
  employeeId String            @db.Uuid
  companyId  String            @db.Uuid
  provider   FaceProvider      @default(COMPREFACE)
  subjectId  String
  status     FaceProfileStatus @default(REGISTERED)
  notes      String?
  lastSyncAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  company    Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee   Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([provider, subjectId, companyId])
  @@index([employeeId, companyId])
  @@map("face_profiles")
}

model MessageThread {
  id         String       @id @default(uuid()) @db.Uuid
  companyId  String       @db.Uuid
  employeeId String       @db.Uuid
  subject    String?
  status     ThreadStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee   Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@unique([companyId, employeeId])
  @@index([employeeId, status])
  @@map("message_threads")
}

model Message {
  id               String              @id @default(uuid()) @db.Uuid
  threadId         String              @db.Uuid
  companyId        String              @db.Uuid
  employeeId       String              @db.Uuid
  senderUserId     String?             @db.Uuid
  senderEmployeeId String?             @db.Uuid
  type             MessageType         @default(TEXT)
  content          String?
  isRead           Boolean             @default(false)
  readAt           DateTime?
  createdAt        DateTime            @default(now())
  attachments      MessageAttachment[]
  company          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee         Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  senderEmployee   Employee?           @relation("SenderEmployee", fields: [senderEmployeeId], references: [id], onDelete: Cascade)
  senderUser       User?               @relation(fields: [senderUserId], references: [id], onDelete: SetNull)
  thread           MessageThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([employeeId, createdAt])
  @@map("messages")
}

model MessageAttachment {
  id           String   @id @default(uuid()) @db.Uuid
  messageId    String   @db.Uuid
  url          String
  filename     String
  mimeType     String?
  sizeBytes    Int?
  thumbnailUrl String?  // URL da thumbnail (para PDFs)
  pageCount    Int?     // Número de páginas (para PDFs)
  createdAt    DateTime @default(now())
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("message_attachments")
}

model ContactInfo {
  id                         String    @id @default(uuid()) @db.Uuid
  companyId                  String?   @unique @db.Uuid
  employeeId                 String?   @unique @db.Uuid
  phoneFixed                 String?
  phoneWhatsapp              String?
  allowWhatsappNotifications Boolean   @default(false)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  company                    Company?  @relation("CompanyContactInfo", fields: [companyId], references: [id], onDelete: Cascade)
  employee                   Employee? @relation("EmployeeContactInfo", fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("contact_info")
}

model Address {
  id         String    @id @default(uuid()) @db.Uuid
  companyId  String?   @unique @db.Uuid
  employeeId String?   @unique @db.Uuid
  zipCode    String
  street     String
  number     String
  complement String?
  district   String
  city       String
  state      String
  reference  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  company    Company?  @relation("CompanyAddress", fields: [companyId], references: [id], onDelete: Cascade)
  employee   Employee? @relation("EmployeeAddress", fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

enum Role {
  SUPER_ADMIN   // Super Admin
  COMPANY_ADMIN // Admin da Empresa
  MANAGER       // Gerente
  HR            // Recursos Humanos
  EMPLOYEE      // Funcionário
  FINANCIAL     // Financeiro
}

enum TimeEntryType {
  CLOCK_IN
  CLOCK_OUT
  BREAK_START
  BREAK_END
}

enum TimeEntryStatus {
  VALID
  PENDING
  INVALID
  ADJUSTED
  SUSPICIOUS
}

enum GeofenceStatus {
  INSIDE
  OUTSIDE
  BORDERLINE
}

enum ClockMethod {
  MANUAL
  FACIAL_RECOGNITION
  QR_CODE
}

enum CompanyPlan {
  TRIAL
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum ComplianceLevel {
  FULL        // Rígido: 100% CLT, bloqueia violações
  FLEXIBLE    // Flexível: sem validações
  CUSTOM      // Customizado: admin escolhe regras
}

enum NotificationType {
  TIMECLOCK
  SYSTEM
  PAYMENT
  SECURITY
  VACATION
}

enum GeofencePolicy {
  ALLOW
  BLOCK
  ALLOW_WITH_JUSTIFICATION
  REQUIRE_LIVENESS
}

enum FaceProvider {
  COMPREFACE
}

enum FaceProfileStatus {
  REGISTERED
  REMOVED
  PENDING
}

enum ThreadStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum MessageType {
  TEXT
  FILE
}

enum OvertimeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OvertimeType {
  BEFORE    // Antes do expediente
  AFTER     // Depois do expediente
  HOLIDAY   // Feriado/DSR
}

// ==========================================
// FOLHA DE PAGAMENTO (Payroll)
// ==========================================

// Folha de pagamento mensal da empresa
model Payroll {
  id              String        @id @default(uuid()) @db.Uuid
  companyId       String        @db.Uuid
  referenceMonth  Int           // Mês de referência (1-12)
  referenceYear   Int           // Ano de referência
  status          PayrollStatus @default(DRAFT)
  totalGross      Decimal       @default(0) @db.Decimal(12, 2) // Total bruto
  totalDeductions Decimal       @default(0) @db.Decimal(12, 2) // Total descontos
  totalNet        Decimal       @default(0) @db.Decimal(12, 2) // Total líquido
  totalEmployees  Int           @default(0)                     // Qtd funcionários
  closedAt        DateTime?                                     // Data de fechamento
  closedBy        String?       @db.Uuid                        // Quem fechou
  paidAt          DateTime?                                     // Data de pagamento
  notes           String?                                       // Observações
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payslips        Payslip[]

  @@unique([companyId, referenceMonth, referenceYear])
  @@index([companyId, referenceYear, referenceMonth])
  @@map("payrolls")
}

// Holerite individual do funcionário
model Payslip {
  id                  String        @id @default(uuid()) @db.Uuid
  payrollId           String        @db.Uuid
  employeeId          String        @db.Uuid
  companyId           String        @db.Uuid
  referenceMonth      Int           // Mês de referência
  referenceYear       Int           // Ano de referência
  status              PayslipStatus @default(PENDING)
  
  // Dados do funcionário no momento (snapshot)
  employeeName        String
  employeePosition    String?
  employeeDepartment  String?
  employeeRegistration String       // Matrícula
  
  // Salário base
  baseSalary          Decimal       @db.Decimal(10, 2)
  
  // Proventos (earnings / rendimentos)
  workedDays          Int           @default(0)  // Dias trabalhados
  workedHours         Decimal       @default(0) @db.Decimal(6, 2) // Horas trabalhadas
  overtimeHours50     Decimal       @default(0) @db.Decimal(6, 2) // Horas extras 50%
  overtimeValue50     Decimal       @default(0) @db.Decimal(10, 2)
  overtimeHours100    Decimal       @default(0) @db.Decimal(6, 2) // Horas extras 100%
  overtimeValue100    Decimal       @default(0) @db.Decimal(10, 2)
  nightShiftHours     Decimal       @default(0) @db.Decimal(6, 2) // Horas noturnas
  nightShiftValue     Decimal       @default(0) @db.Decimal(10, 2)
  hazardPay           Decimal       @default(0) @db.Decimal(10, 2) // Periculosidade
  unhealthyPay        Decimal       @default(0) @db.Decimal(10, 2) // Insalubridade
  bonus               Decimal       @default(0) @db.Decimal(10, 2) // Bônus/Gratificações
  otherEarnings       Decimal       @default(0) @db.Decimal(10, 2) // Outros proventos
  otherEarningsDesc   String?                                       // Descrição outros proventos
  vacationDays        Int           @default(0)                     // Dias de férias pagos neste mês
  vacationPayValue    Decimal       @default(0) @db.Decimal(10, 2) // Remuneração de férias (salário/30 × dias)
  vacationBonusValue  Decimal       @default(0) @db.Decimal(10, 2) // 1/3 constitucional de férias
  vacationSellDays    Int           @default(0)                     // Dias vendidos (abono pecuniário)
  vacationSellValue   Decimal       @default(0) @db.Decimal(10, 2) // Valor do abono pecuniário
  totalVacationEarnings Decimal     @default(0) @db.Decimal(10, 2) // Total proventos de férias
  totalEarnings       Decimal       @default(0) @db.Decimal(12, 2) // Total proventos
  
  // Descontos (deductions)
  absenceDays         Int           @default(0)  // Dias de falta (não justificados)
  absenceValue        Decimal       @default(0) @db.Decimal(10, 2)
  justifiedAbsenceDays Int          @default(0)  // Dias justificados por atestado
  lateMinutes         Int           @default(0)  // Minutos de atraso
  lateValue           Decimal       @default(0) @db.Decimal(10, 2) // Valor do atraso (sempre calculado para análise)
  lateDiscounted      Boolean       @default(true) // Se true, lateValue foi descontado; se false, apenas registrado
  inssBase            Decimal       @default(0) @db.Decimal(10, 2) // Base INSS
  inssValue           Decimal       @default(0) @db.Decimal(10, 2) // Desconto INSS
  inssRate            Decimal       @default(0) @db.Decimal(5, 2)  // Alíquota INSS
  irBase              Decimal       @default(0) @db.Decimal(10, 2) // Base IR
  irValue             Decimal       @default(0) @db.Decimal(10, 2) // Desconto IR
  irRate              Decimal       @default(0) @db.Decimal(5, 2)  // Alíquota IR
  transportVoucher    Decimal       @default(0) @db.Decimal(10, 2) // Vale-transporte (6%)
  mealVoucher         Decimal       @default(0) @db.Decimal(10, 2) // Vale-refeição
  healthInsurance     Decimal       @default(0) @db.Decimal(10, 2) // Plano de saúde
  dentalInsurance     Decimal       @default(0) @db.Decimal(10, 2) // Plano odontológico
  unionContribution   Decimal       @default(0) @db.Decimal(10, 2) // Contribuição sindical
  loanDeduction       Decimal       @default(0) @db.Decimal(10, 2) // Empréstimo consignado
  advancePayment      Decimal       @default(0) @db.Decimal(10, 2) // Adiantamento
  otherDeductions     Decimal       @default(0) @db.Decimal(10, 2) // Outros descontos
  otherDeductionsDesc String?                                       // Descrição outros descontos
  totalDeductions     Decimal       @default(0) @db.Decimal(12, 2) // Total descontos
  
  // FGTS (não desconta do funcionário, mas é obrigação da empresa)
  fgtsBase            Decimal       @default(0) @db.Decimal(10, 2)
  fgtsValue           Decimal       @default(0) @db.Decimal(10, 2) // 8% do salário
  
  // Totais
  grossSalary         Decimal       @default(0) @db.Decimal(12, 2) // Salário bruto
  netSalary           Decimal       @default(0) @db.Decimal(12, 2) // Salário líquido
  
  // Controle
  calculatedAt        DateTime?                                     // Quando foi calculado
  approvedAt          DateTime?                                     // Quando foi aprovado pelo admin
  approvedBy          String?       @db.Uuid                        // Quem aprovou (admin)
  acceptedAt          DateTime?                                     // Quando foi aceito pelo funcionário
  rejectedAt          DateTime?                                     // Quando foi rejeitado pelo funcionário
  rejectionReason     String?                                       // Motivo da rejeição pelo funcionário
  paidAt              DateTime?                                     // Quando foi pago
  notes               String?                                       // Observações
  
  // Adiantamentos (descontados neste holerite)
  salaryAdvanceValue  Decimal       @default(0) @db.Decimal(10, 2)  // Adiantamento salarial (% automático)
  extraAdvanceValue   Decimal       @default(0) @db.Decimal(10, 2)  // Vales avulsos (sob demanda)
  
  // Assinatura digital do funcionário
  viewedAt            DateTime?                                     // Data/hora que visualizou o holerite
  scrolledToEnd       Boolean       @default(false)                 // Rolou até o final (obrigatório para assinar)
  scrolledAt          DateTime?                                     // Data/hora que rolou até o final
  signedAt            DateTime?                                     // Data/hora da assinatura
  signedByIp          String?                                       // IP do dispositivo
  signedByDevice      String?                                       // User-Agent (dispositivo)
  documentHash        String?                                       // Hash SHA-256 do holerite
  signatureTerms      Boolean       @default(false)                 // Aceitou os termos
  pdfPath             String?                                       // Caminho do PDF no MinIO
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  
  company             Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee            Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payroll             Payroll       @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  customBenefits      PayslipBenefit[]
  discountedAdvances  Advance[]                                     // Adiantamentos descontados
  installments        PayslipInstallment[]                          // Parcelas de pagamento

  @@unique([payrollId, employeeId])
  @@index([companyId, referenceYear, referenceMonth])
  @@index([employeeId, referenceYear, referenceMonth])
  @@map("payslips")
}

// Parcelas de pagamento do holerite
model PayslipInstallment {
  id                  String    @id @default(uuid()) @db.Uuid
  payslipId           String    @db.Uuid
  installmentNumber   Int                                           // Número da parcela (1, 2, 3, 4)
  totalInstallments   Int                                           // Total de parcelas
  percentage          Decimal   @db.Decimal(5, 2)                   // % desta parcela
  amount              Decimal   @db.Decimal(12, 2)                  // Valor calculado
  dueDate             DateTime  @db.Date                            // Data prevista de pagamento
  paidAt              DateTime?                                     // Quando foi pago
  paidBy              String?   @db.Uuid                            // Quem pagou
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  payslip             Payslip   @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  
  @@unique([payslipId, installmentNumber])
  @@index([payslipId])
  @@index([dueDate])
  @@map("payslip_installments")
}

// Status da folha de pagamento
enum PayrollStatus {
  DRAFT       // Rascunho - em elaboração
  CALCULATING // Calculando
  REVIEW      // Em revisão
  APPROVED    // Aprovada
  PAID        // Paga
  CANCELLED   // Cancelada
}

// Status do holerite individual
enum PayslipStatus {
  PENDING     // Pendente de cálculo
  CALCULATED  // Calculado
  APPROVED    // Aprovado pelo admin
  ACCEPTED    // Aceito pelo funcionário (👍)
  REJECTED    // Rejeitado pelo funcionário (👎)
  PAID        // Pago
  CANCELLED   // Cancelado
}

// Modo de pagamento da empresa
enum PaymentMode {
  FULL          // Mensal - pagamento único (100% de uma vez)
  ADVANCE       // Adiantamento - vale + saldo (ex: 40% dia 15 + 60% dia 5)
  INSTALLMENTS  // Parcelado - divide em 2 ou 4 parcelas iguais ou personalizadas
}

// ==========================================
// ATESTADOS MÉDICOS
// ==========================================

// Atestado médico do funcionário
model MedicalCertificate {
  id              String    @id @default(uuid()) @db.Uuid
  companyId       String    @db.Uuid
  employeeId      String    @db.Uuid
  
  startDate       DateTime  @db.Date                    // Data início do atestado
  endDate         DateTime  @db.Date                    // Data fim do atestado
  days            Int                                   // Quantidade de dias
  reason          String?                               // Motivo/CID (opcional)
  doctorName      String?                               // Nome do médico
  doctorCrm       String?                               // CRM do médico
  attachmentUrl   String?                               // URL do arquivo anexo
  notes           String?                               // Observações
  
  status          MedicalCertificateStatus @default(PENDING)
  approvedAt      DateTime?
  approvedBy      String?   @db.Uuid
  rejectedAt      DateTime?
  rejectedBy      String?   @db.Uuid
  rejectionReason String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([companyId, employeeId])
  @@index([startDate, endDate])
  @@map("medical_certificates")
}

// Status do atestado médico
enum MedicalCertificateStatus {
  PENDING   // Aguardando aprovação
  APPROVED  // Aprovado
  REJECTED  // Rejeitado
}

// ==========================================
// CONFIGURAÇÕES DE FOLHA DE PAGAMENTO
// ==========================================

// Configurações de folha de pagamento da empresa
model PayrollConfig {
  id                    String        @id @default(uuid()) @db.Uuid
  companyId             String        @unique @db.Uuid
  
  // Encargos obrigatórios (ativar/desativar)
  enableInss            Boolean       @default(true)       // Desconta INSS do funcionário
  enableIrrf            Boolean       @default(true)       // Desconta IRRF do funcionário
  enableFgts            Boolean       @default(true)       // Empresa paga FGTS (8%)
  
  // Desconto de atrasos
  enableLateDiscount    Boolean       @default(true)       // Desconta atrasos do funcionário (padrão: SIM)
                                                           // Se false: NÃO desconta, mas registra para análise
  
  // Adicional Noturno (22h às 05h = +20%) - DESABILITADO por padrão
  enableNightShift      Boolean       @default(false)      // Habilitar adicional noturno
  nightShiftStart       String        @default("22:00")    // Início do horário noturno
  nightShiftEnd         String        @default("05:00")    // Fim do horário noturno
  nightShiftPercentage  Decimal       @default(20) @db.Decimal(5, 2) // % adicional noturno
  
  // Vale Avulso (Sob Demanda - valor fixo)
  enableExtraAdvance    Boolean       @default(false)      // Habilitar vale avulso
  maxExtraAdvancePercentage Decimal?  @db.Decimal(5, 2)    // Limite máximo % do salário (ex: 50)
  
  // Benefícios padrão da empresa (valores default para funcionários)
  enableTransportVoucher Boolean      @default(true)       // Vale-transporte habilitado
  transportVoucherRate  Decimal       @default(6) @db.Decimal(5, 2) // % desconto VT (padrão 6%)
  enableMealVoucher     Boolean       @default(false)      // Vale-refeição habilitado
  mealVoucherValue      Decimal       @default(0) @db.Decimal(10, 2) // Valor VR que funcionário recebe
  mealVoucherDiscount   Decimal       @default(0) @db.Decimal(5, 2)  // % desconto VR do salário
  enableHealthInsurance Boolean       @default(false)      // Plano de saúde habilitado
  healthInsuranceValue  Decimal       @default(0) @db.Decimal(10, 2) // Valor desconto plano saúde
  enableDentalInsurance Boolean       @default(false)      // Plano odontológico habilitado
  dentalInsuranceValue  Decimal       @default(0) @db.Decimal(10, 2) // Valor desconto plano odonto
  
  // 13º e Férias
  enable13thSalary      Boolean       @default(true)       // Paga 13º salário
  enableVacationBonus   Boolean       @default(true)       // Paga 1/3 de férias
  
  // ==========================================
  // MODO DE PAGAMENTO FLEXÍVEL
  // ==========================================
  
  // Modo de pagamento (padrão: FULL = mensal, uma vez no dia 5)
  paymentMode           PaymentMode   @default(FULL)
  
  // Configuração FULL (Mensal - pagamento único)
  fullPaymentDay        Int           @default(5)          // Dia do pagamento único
  
  // Configuração ADVANCE (Adiantamento - vale + saldo)
  advancePercent        Decimal       @default(40) @db.Decimal(5, 2)  // % do adiantamento (padrão 40%)
  advancePaymentDay     Int           @default(15)         // Dia do adiantamento
  balancePaymentDay     Int           @default(5)          // Dia do saldo (mês seguinte)
  
  // Configuração INSTALLMENTS (Parcelado - 2 ou 4 parcelas)
  installmentCount      Int           @default(2)          // Quantidade de parcelas (2 ou 4)
  
  // Parcela 1
  installment1Percent   Decimal       @default(50) @db.Decimal(5, 2)  // % da parcela 1
  installment1Day       Int           @default(15)         // Dia da parcela 1
  
  // Parcela 2
  installment2Percent   Decimal       @default(50) @db.Decimal(5, 2)  // % da parcela 2
  installment2Day       Int           @default(30)         // Dia da parcela 2
  
  // Parcela 3 (só se installmentCount = 4)
  installment3Percent   Decimal       @default(0) @db.Decimal(5, 2)   // % da parcela 3
  installment3Day       Int?                               // Dia da parcela 3
  
  // Parcela 4 (só se installmentCount = 4)
  installment4Percent   Decimal       @default(0) @db.Decimal(5, 2)   // % da parcela 4
  installment4Day       Int?                               // Dia da parcela 4
  
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  
  company               Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@map("payroll_configs")
}

// Benefícios personalizados da empresa
model CustomBenefit {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @db.Uuid
  name        String                                      // Nome do benefício (ex: "Ajuda Aluguel")
  description String?                                     // Descrição opcional
  value       Decimal   @db.Decimal(10, 2)                // Valor do benefício
  type        BenefitType @default(EARNING)               // Provento ou Desconto
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   EmployeeBenefit[]
  payslipBenefits PayslipBenefit[]
  
  @@unique([companyId, name])
  @@map("custom_benefits")
}

// Vínculo funcionário-benefício (quem recebe qual benefício)
model EmployeeBenefit {
  id          String    @id @default(uuid()) @db.Uuid
  employeeId  String    @db.Uuid
  benefitId   String    @db.Uuid
  customValue Decimal?  @db.Decimal(10, 2)                // Valor personalizado (se diferente do padrão)
  active      Boolean   @default(true)
  startDate   DateTime  @default(now())                   // Quando começou a receber
  endDate     DateTime?                                   // Quando parou (null = ativo)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  benefit     CustomBenefit @relation(fields: [benefitId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, benefitId])
  @@map("employee_benefits")
}

// Benefícios aplicados no holerite (histórico)
model PayslipBenefit {
  id          String    @id @default(uuid()) @db.Uuid
  payslipId   String    @db.Uuid
  benefitId   String    @db.Uuid
  name        String                                      // Nome do benefício (snapshot)
  value       Decimal   @db.Decimal(10, 2)                // Valor aplicado
  type        BenefitType                                 // Provento ou Desconto
  createdAt   DateTime  @default(now())
  
  payslip     Payslip   @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  benefit     CustomBenefit @relation(fields: [benefitId], references: [id], onDelete: Cascade)
  
  @@map("payslip_benefits")
}

// Tipo de benefício
enum BenefitType {
  EARNING     // Provento (adiciona ao salário)
  DEDUCTION   // Desconto (subtrai do salário)
}

// ==========================================
// GRUPOS DE PAGAMENTO
// ==========================================

// Grupos de pagamento (funcionários com datas diferentes)
model PaymentGroup {
  id                    String    @id @default(uuid()) @db.Uuid
  companyId             String    @db.Uuid
  name                  String                                      // Nome do grupo (ex: "Administrativo", "Operacional")
  description           String?                                     // Descrição opcional
  paymentDay1           Int                                         // Primeiro dia de pagamento
  paymentDay2           Int?                                        // Segundo dia (se quinzenal)
  advanceDay            Int?                                        // Dia do adiantamento salarial
  advancePercentage     Decimal?  @db.Decimal(5, 2)                 // % do adiantamento (ex: 40)
  active                Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  company               Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees             Employee[]
  
  @@unique([companyId, name])
  @@map("payment_groups")
}

// ==========================================
// ADIANTAMENTOS E VALES
// ==========================================

// Tipo de adiantamento
enum AdvanceType {
  SALARY_ADVANCE  // Adiantamento salarial automático (% do salário)
  EXTRA_ADVANCE   // Vale avulso sob demanda (valor fixo)
}

// Status do adiantamento
enum AdvanceStatus {
  PENDING     // Aguardando aprovação
  APPROVED    // Aprovado
  PAID        // Pago ao funcionário
  DISCOUNTED  // Descontado no holerite
  REJECTED    // Rejeitado
}

// Adiantamentos e vales
model Advance {
  id              String        @id @default(uuid()) @db.Uuid
  companyId       String        @db.Uuid
  employeeId      String        @db.Uuid
  type            AdvanceType                                       // SALARY_ADVANCE ou EXTRA_ADVANCE
  amount          Decimal       @db.Decimal(10, 2)                  // Valor do adiantamento
  percentage      Decimal?      @db.Decimal(5, 2)                   // % do salário (só para SALARY_ADVANCE)
  referenceMonth  Int                                               // Mês de referência
  referenceYear   Int                                               // Ano de referência
  requestDate     DateTime      @default(now())                     // Data da solicitação
  paymentDate     DateTime?                                         // Data do pagamento
  status          AdvanceStatus @default(PENDING)
  reason          String?                                           // Motivo (para EXTRA_ADVANCE)
  approvedById    String?       @db.Uuid                            // Quem aprovou
  approvedAt      DateTime?                                         // Data da aprovação
  rejectedReason  String?                                           // Motivo da rejeição
  payslipId       String?       @db.Uuid                            // Holerite onde foi descontado
  notes           String?                                           // Observações
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payslip         Payslip?      @relation(fields: [payslipId], references: [id], onDelete: SetNull)
  
  @@index([companyId, referenceYear, referenceMonth])
  @@index([employeeId, referenceYear, referenceMonth])
  @@index([status])
  @@map("advances")
}

// ==========================================
// SISTEMA DE PERMISSÕES (RBAC + ACL)
// ==========================================

// Permissões disponíveis no sistema (seed)
model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  module      String   // employees, payroll, overtime, etc.
  action      String   // view, create, edit, delete, approve, etc.
  key         String   @unique // employees.view, payroll.approve
  description String   // "Visualizar funcionários"
  createdAt   DateTime @default(now())
  
  rolePermissions RolePermission[]
  
  @@unique([module, action])
  @@map("permissions")
}

// Permissões por Role por Empresa (configurável pelo admin)
model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  companyId    String     @db.Uuid
  role         Role       // MANAGER, HR, FINANCIAL (não SUPER_ADMIN nem COMPANY_ADMIN)
  permissionId String     @db.Uuid
  granted      Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  @@unique([companyId, role, permissionId])
  @@index([companyId, role])
  @@map("role_permissions")
}

// Logs de Auditoria (todas as ações do sistema)
model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @db.Uuid
  userId      String?  @db.Uuid
  userName    String   // Nome do usuário (para histórico)
  userRole    Role     // Role no momento da ação
  action      String   // CREATE, UPDATE, DELETE, VIEW, LOGIN, LOGOUT, APPROVE, REJECT
  module      String   // employees, payroll, time_entries, etc.
  entityId    String?  // ID do registro afetado
  entityName  String?  // Nome/descrição do registro (para histórico)
  oldData     Json?    // Dados antes da alteração
  newData     Json?    // Dados depois da alteração
  ip          String?  // IP do usuário
  userAgent   String?  // Navegador/dispositivo
  timestamp   DateTime @default(now())
  
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([companyId, timestamp])
  @@index([companyId, module])
  @@index([userId])
  @@index([module, entityId])
  @@map("audit_logs")
}

// ==========================================
// CALENDÁRIO DE FERIADOS (Holidays)
// ==========================================

// Feriados nacionais, estaduais, municipais ou da empresa
model Holiday {
  id          String      @id @default(uuid()) @db.Uuid
  companyId   String      @db.Uuid
  name        String      // Nome do feriado (ex: "Natal", "Dia do Trabalho")
  date        DateTime    @db.Date // Data do feriado
  type        HolidayType @default(NATIONAL) // Tipo do feriado
  recurring   Boolean     @default(true) // Se repete todo ano (ex: Natal = true, Carnaval = false)
  halfDay     Boolean     @default(false) // Meio período (ponto facultativo)
  active      Boolean     @default(true)
  notes       String?     // Observações
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@unique([companyId, date, name])
  @@index([companyId, date])
  @@index([companyId, active])
  @@map("holidays")
}

enum HolidayType {
  NATIONAL    // Feriado nacional (ex: Independência)
  STATE       // Feriado estadual (ex: Revolução Constitucionalista em SP)
  MUNICIPAL   // Feriado municipal (ex: Aniversário da cidade)
  COMPANY     // Feriado/folga da empresa
  OPTIONAL    // Ponto facultativo
}

// ==========================================
// FÉRIAS (Vacation)
// ==========================================

// Período de férias do funcionário
model Vacation {
  id                String          @id @default(uuid()) @db.Uuid
  employeeId        String          @db.Uuid
  companyId         String          @db.Uuid
  
  // Período aquisitivo (12 meses para adquirir direito)
  acquisitionStart  DateTime        @db.Date  // Início do período aquisitivo
  acquisitionEnd    DateTime        @db.Date  // Fim do período aquisitivo (12 meses depois)
  
  // Período concessivo (12 meses para a empresa conceder)
  concessionStart   DateTime        @db.Date  // Início do período concessivo
  concessionEnd     DateTime        @db.Date  // Fim do período concessivo
  
  // Dias de direito
  totalDays         Int             @default(30)  // Total de dias de direito (pode ser menor se muitas faltas)
  soldDays          Int             @default(0)   // Dias vendidos (abono pecuniário, máx 10)
  usedDays          Int             @default(0)   // Dias já usufruídos
  remainingDays     Int             @default(30)  // Dias restantes a gozar
  
  // Status geral das férias
  status            VacationStatus  @default(PENDING)
  
  // Aprovação
  approvedBy        String?         @db.Uuid
  approvedAt        DateTime?
  
  // Regularização (para férias já pagas/gozadas antes da migração)
  regularizedAt     DateTime?                 // Data em que foi regularizado no sistema
  regularizedBy     String?         @db.Uuid  // Quem regularizou
  regularizationType String?                  // 'ENJOYED' (gozadas) ou 'PAID_DOUBLE' (pagas em dobro)
  regularizationDate DateTime?      @db.Date  // Data em que as férias foram efetivamente gozadas/pagas
  
  // Observações
  notes             String?
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  // Relacionamentos
  employee          Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  approver          User?           @relation(fields: [approvedBy], references: [id], onDelete: SetNull)
  periods           VacationPeriod[]
  requests          VacationRequest[]
  
  @@index([employeeId, status])
  @@index([companyId, status])
  @@index([companyId, concessionEnd])
  @@map("vacations")
}

// Período de gozo das férias (pode ter até 3 períodos)
model VacationPeriod {
  id              String                @id @default(uuid()) @db.Uuid
  vacationId      String                @db.Uuid
  
  periodNumber    Int                   // 1, 2 ou 3
  startDate       DateTime              @db.Date  // Data início do período
  endDate         DateTime              @db.Date  // Data fim do período
  days            Int                   // Quantidade de dias corridos
  
  // Pagamento (deve ser feito até 2 dias antes do início)
  paymentDueDate  DateTime?             @db.Date  // Data limite para pagamento
  baseValue       Decimal?              @db.Decimal(10, 2) // Valor base (salário proporcional)
  bonusValue      Decimal?              @db.Decimal(10, 2) // 1/3 constitucional
  totalValue      Decimal?              @db.Decimal(10, 2) // Total a pagar
  paidAt          DateTime?             // Quando foi pago
  
  // Status do período
  status          VacationPeriodStatus  @default(SCHEDULED)
  
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  
  // Relacionamentos
  vacation        Vacation              @relation(fields: [vacationId], references: [id], onDelete: Cascade)
  
  @@index([vacationId, periodNumber])
  @@index([startDate, endDate])
  @@map("vacation_periods")
}

enum VacationStatus {
  PENDING       // Aguardando programação
  SCHEDULED     // Programado (períodos definidos)
  IN_PROGRESS   // Em andamento (pelo menos 1 período iniciou)
  COMPLETED     // Concluído (todos os dias gozados)
  EXPIRED       // Vencido (não tirou no período concessivo - paga em dobro!)
  REGULARIZED   // Regularizado (férias já pagas/gozadas antes da migração do sistema)
  CANCELLED     // Cancelado
}

enum VacationPeriodStatus {
  SCHEDULED     // Agendado
  IN_PROGRESS   // Em andamento
  COMPLETED     // Concluído
  CANCELLED     // Cancelado
}

// ==========================================
// SOLICITAÇÃO DE FÉRIAS (Vacation Request)
// ==========================================

// Solicitação de férias pelo funcionário
model VacationRequest {
  id                  String                @id @default(uuid()) @db.Uuid
  employeeId          String                @db.Uuid
  companyId           String                @db.Uuid
  vacationId          String?               @db.Uuid  // Período aquisitivo relacionado
  
  // Dados da solicitação
  requestedStartDate  DateTime              @db.Date  // Data início solicitada
  requestedDays       Int                   // Quantidade de dias solicitados
  
  // Divisão de períodos (opcional - JSON com até 3 períodos)
  // Ex: [{ startDate: "2026-01-15", days: 15 }, { startDate: "2026-07-01", days: 15 }]
  requestedPeriods    Json?
  
  // Abono pecuniário (venda de dias)
  sellDays            Int                   @default(0)  // Dias a vender (máx 10 pela CLT)
  
  // Observações do funcionário
  employeeNotes       String?
  
  // Status da solicitação
  status              VacationRequestStatus @default(PENDING)
  
  // Contraproposta do admin (se houver)
  counterProposal     Json?                 // { startDate, days, periods, sellDays, notes }
  counterProposalAt   DateTime?
  counterProposalBy   String?               @db.Uuid
  counterProposalNotes String?
  
  // Resposta do funcionário à contraproposta
  counterResponseAt   DateTime?
  counterAccepted     Boolean?
  counterResponseNotes String?
  
  // Aprovação final
  approvedAt          DateTime?
  approvedBy          String?               @db.Uuid
  rejectedAt          DateTime?
  rejectedBy          String?               @db.Uuid
  rejectionReason     String?
  
  // Assinatura do funcionário
  employeeViewedAt    DateTime?             // Quando visualizou o aviso
  employeeScrolledAt  DateTime?             // Quando rolou até o final (obrigatório para assinar)
  employeeScrolled    Boolean               @default(false) // Rolou até o final
  employeeSignedAt    DateTime?             // Quando assinou
  employeeSignedIp    String?               // IP da assinatura
  employeeSignedDevice String?              // User-Agent
  employeeSignatureHash String?             // Hash da assinatura
  
  // Assinatura do admin/RH
  adminSignedAt       DateTime?             // Quando o admin assinou
  adminSignedBy       String?               @db.Uuid
  adminSignedIp       String?
  adminSignedDevice   String?
  adminSignatureHash  String?
  
  // Documento gerado
  documentHash        String?               // Hash SHA-256 do documento
  pdfPath             String?               // Caminho do PDF no MinIO
  
  // Validações CLT (registrar se houve violação)
  cltViolations       Json?                 // Array de violações detectadas
  cltWarningsIgnored  Boolean               @default(false) // Se ignorou avisos (modo FLEXIBLE)
  
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  
  // Relacionamentos
  employee            Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company             Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vacation            Vacation?             @relation(fields: [vacationId], references: [id], onDelete: SetNull)
  
  @@index([employeeId, status])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@map("vacation_requests")
}

enum VacationRequestStatus {
  PENDING             // Aguardando análise do admin
  COUNTER_PROPOSAL    // Admin fez contraproposta, aguardando resposta do funcionário
  APPROVED            // Aprovado pelo admin
  REJECTED            // Rejeitado pelo admin
  AWAITING_SIGNATURE  // Aprovado, aguardando assinaturas
  EMPLOYEE_SIGNED     // Funcionário assinou, aguardando admin
  COMPLETED           // Ambos assinaram, processo concluído
  CANCELLED           // Cancelado
}

// Regime de trabalho da empresa
enum WorkRegime {
  SINGLE_SHIFT     // Turno único (apenas horário comercial diurno)
  MULTIPLE_SHIFTS  // Múltiplos turnos (manhã, tarde, noite)
  CONTINUOUS_24H   // Operação 24 horas (hospitais, fábricas, segurança)
}

// Escala de trabalho do funcionário
enum WorkSchedule {
  FIVE_TWO          // 5x2 - Segunda a Sexta (22 dias/mês, folga sáb/dom)
  SIX_ONE           // 6x1 - Segunda a Sábado (26 dias/mês, folga dom)
  TWELVE_THIRTYSIX  // 12x36 - 12h trabalha, 36h folga (~15 dias/mês)
  FOUR_TWO          // 4x2 - 4 dias trabalha, 2 folga (~20 dias/mês)
  CUSTOM            // Personalizado (usa workDaysPerMonth manual no funcionário)
}
