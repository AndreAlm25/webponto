# Aplicação
NODE_ENV=development
PORT=4000

# Banco de dados
DATABASE_URL="postgresql://webponto:webponto123@localhost:5432/webponto_db?schema=public"

# JWT
JWT_SECRET=change-this-super-secret-key-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=change-this-refresh-token-secret
REFRESH_TOKEN_EXPIRES_IN=30d

# MinIO (S3)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_USE_SSL=false
MINIO_BUCKET_PONTOS=pontos
MINIO_BUCKET_FUNCIONARIOS=funcionarios

# CompreFace (Reconhecimento Facial)
COMPREFACE_API_URL=http://localhost:8080
COMPREFACE_API_KEY=00000000-0000-0000-0000-000000000002
COMPREFACE_THRESHOLD=0.9          # Threshold de similaridade (0.0-1.0)
COMPREFACE_DET_PROB=0.2           # Probabilidade de detecção

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS
CORS_ORIGIN=http://localhost:3000

# Taxa de limite (requests por minuto)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
